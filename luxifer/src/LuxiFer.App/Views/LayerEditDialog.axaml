<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LuxiFer.App.ViewModels"
        xmlns:canvas="using:LuxiFer.Core.Canvas"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="420"
        x:Class="LuxiFer.App.Views.LayerEditDialog"
        x:DataType="canvas:Layer"
        Title="Layer bearbeiten"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#9a9aa0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox, ComboBox, CheckBox">
            <Setter Property="Margin" Value="0,3"/>
        </Style>
    </Window.Styles>

    <StackPanel Margin="18" Spacing="4">
        <TextBlock Text="Layer-Parameter" FontWeight="Bold" FontSize="15" Margin="0,0,0,8"/>

        <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            <TextBlock Classes="label" Grid.Row="0" Grid.Column="0" Text="Name"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name}"/>

            <TextBlock Classes="label" Grid.Row="1" Grid.Column="0" Text="Modus"/>
            <ComboBox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch"
                      ItemsSource="{x:Static vm:MainWindowViewModel.LayerModes}"
                      SelectedItem="{Binding Mode}"/>

            <TextBlock Classes="label" Grid.Row="2" Grid.Column="0" Text="Speed mm/s"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SpeedMmS}"/>

            <TextBlock Classes="label" Grid.Row="3" Grid.Column="0" Text="Power %"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PowerPct}"/>

            <TextBlock Classes="label" Grid.Row="4" Grid.Column="0" Text="Min-Power %"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding MinPowerPct}"/>

            <TextBlock Classes="label" Grid.Row="5" Grid.Column="0" Text="Passes"/>
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Passes}"/>

            <TextBlock Classes="label" Grid.Row="6" Grid.Column="0" Text="Air Assist"/>
            <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding AirAssist}"/>
        </Grid>

        <Button Content="Schließen" HorizontalAlignment="Right" Margin="0,12,0,0"
                Click="OnCloseClick"/>
    </StackPanel>
</Window>
