<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="using:LuxiFer.App.Controls"
             xmlns:canvas="using:LuxiFer.Core.Canvas"
             xmlns:vm="using:LuxiFer.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="240" d:DesignHeight="500"
             x:Class="LuxiFer.App.Controls.LayerPanel"
             x:DataType="vm:MainWindowViewModel">

    <DockPanel Margin="10">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="+" Width="30"
                    Command="{Binding AddLayerCommand}" ToolTip.Tip="Layer hinzufügen"/>
            <TextBlock Text="Schnitte / Ebenen" FontWeight="Bold" VerticalAlignment="Center"/>
        </DockPanel>
        <ListBox ItemsSource="{Binding Layers}" SelectedItem="{Binding ActiveLayer}"
                 Background="Transparent" DoubleTapped="OnLayerDoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="canvas:Layer">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="14" Height="14" CornerRadius="3"
                                Background="{Binding ColorHex, Converter={x:Static ctrl:ToolConverters.HexToBrush}}"
                                VerticalAlignment="Center"/>
                        <CheckBox DockPanel.Dock="Right" IsChecked="{Binding Locked}"
                                  Click="OnLayerToggle" ToolTip.Tip="Gesperrt"
                                  Margin="4,0,0,0">🔒</CheckBox>
                        <CheckBox DockPanel.Dock="Right" IsChecked="{Binding Visible}"
                                  Click="OnLayerToggle" ToolTip.Tip="Sichtbar"
                                  Margin="4,0,0,0">👁</CheckBox>
                        <StackPanel VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock Text="{Binding Name}"/>
                            <TextBlock FontSize="10" Foreground="#9a9aa0"
                                       Text="{Binding SpeedMmS, StringFormat='{}{0:0} mm/s'}"/>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
