<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="using:LuxiFer.App.Controls"
             xmlns:canvas="using:LuxiFer.Core.Canvas"
             xmlns:vm="using:LuxiFer.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="240" d:DesignHeight="500"
             x:Class="LuxiFer.App.Controls.LayerPanel"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Styles>
        <Style Selector="ToggleButton.layericon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusSmall}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        </Style>
        <Style Selector="ToggleButton.layericon:checked">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="ToggleButton.layericon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
        </Style>

        <!-- Farbfeld der Zeile: öffnet die Palette -->
        <Style Selector="Button.swatchbtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Einzelnes Palettenfeld im Flyout -->
        <Style Selector="Button.swatch">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Styles>

    <DockPanel Margin="14">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" Classes="icon" Command="{Binding AddLayerCommand}"
                    ToolTip.Tip="Layer hinzufügen">
                <PathIcon Data="{StaticResource IconPlus}" Width="16" Height="16"/>
            </Button>
            <TextBlock Text="SCHNITTE / EBENEN" Classes="h" VerticalAlignment="Center"/>
        </DockPanel>
        <ListBox ItemsSource="{Binding Layers}" SelectedItem="{Binding ActiveLayer}"
                 DoubleTapped="OnLayerDoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="canvas:Layer">
                    <DockPanel>
                        <!-- Farbfeld + Palette (Flyout) -->
                        <Button DockPanel.Dock="Left" Classes="swatchbtn" VerticalAlignment="Center"
                                ToolTip.Tip="Farbe wählen"
                                DataContext="{Binding}"
                                Click="OnSwatchButtonClick">
                            <Border Width="16" Height="16" CornerRadius="4"
                                    Background="{Binding ColorHex, Converter={x:Static ctrl:ToolConverters.HexToBrush}}"
                                    BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"/>
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <ItemsControl ItemsSource="{x:Static canvas:Layer.SwatchColors}"
                                                  Width="180">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Button Classes="swatch" Margin="2"
                                                        Tag="{Binding}"
                                                        Background="{Binding Converter={x:Static ctrl:ToolConverters.HexToBrush}}"
                                                        Click="OnSwatchClick"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- Sicht / Sperre rechts -->
                        <ToggleButton DockPanel.Dock="Right" Classes="layericon"
                                      IsChecked="{Binding Locked}"
                                      Click="OnLayerToggle" ToolTip.Tip="Sperre">
                            <PathIcon Data="{StaticResource IconLock}" Width="15" Height="15"/>
                        </ToggleButton>
                        <ToggleButton DockPanel.Dock="Right" Classes="layericon"
                                      IsChecked="{Binding Visible}"
                                      Click="OnLayerToggle" ToolTip.Tip="Sichtbar">
                            <PathIcon Data="{StaticResource IconEye}" Width="16" Height="16"/>
                        </ToggleButton>

                        <!-- Name + Parameterzeile (Modus · Speed · Power) -->
                        <StackPanel VerticalAlignment="Center" Margin="10,0,8,0" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Classes="muted" FontSize="11"
                                           Text="{Binding Mode, Converter={x:Static ctrl:ToolConverters.ModeLabel}}"/>
                                <TextBlock Classes="muted" FontSize="11" Text="·"/>
                                <TextBlock Classes="muted" FontSize="11"
                                           Text="{Binding SpeedMmS, StringFormat='{}{0:0} mm/s'}"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
